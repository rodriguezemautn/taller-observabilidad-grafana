{
  "name": "taller-observabilidad-grafana",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Taller de Observabilidad con Grafana - Ing. y Calidad de Software",
  "workspaces": [
    "packages/core",
    "packages/infrastructure",
    "packages/web-app"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=packages/infrastructure",
    "dev:web": "npm run dev --workspace=packages/web-app",
    "clean": "npm run clean --workspaces",
    "load": "tsx scripts/load-simulation.ts",
    "load:heavy": "tsx scripts/load-simulation.ts --users 8 --delay-min 100 --delay-max 1500 --invalid-rate 0.2"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0"
  }
}
