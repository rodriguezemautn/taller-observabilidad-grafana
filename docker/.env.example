# ═══════════════════════════════════════════════════════════
#  Taller de Observabilidad — Variables de Entorno
#  Copiá este archivo como .env y ajustá según tu entorno
# ═══════════════════════════════════════════════════════════

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=taller
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Grafana ───────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ─── Versiones de imágenes ─────────────────────────────────
# Usar versiones fijas en vez de "latest" para entornos productivos
# Versiones recomendadas (verificadas con el taller):
# IMAGE_TAG_POSTGRES=16-alpine
# IMAGE_TAG_LOKI=3.4.2
# IMAGE_TAG_TEMPO=2.7.1
# IMAGE_TAG_MIMIR=2.15.0
# IMAGE_TAG_GRAFANA=11.6.0
# IMAGE_TAG_OTEL=0.121.0
# IMAGE_TAG_CADVISOR=v0.49.2
# IMAGE_TAG_NODE_EXPORTER=1.9.1
# IMAGE_TAG_POSTGRES_EXPORTER=v0.17.1

# ─── Rutas (relativas a docker/) ───────────────────────────
# No cambiar a menos que sepas lo que hacés
# OTEL_CONFIG=./otel-collector/config.yml
# MIMIR_CONFIG=./mimir.yml
# MIMIR_OVERRIDES=./mimir-overrides.yaml
# GRAFANA_DATASOURCES=./grafana/datasources.yml
# GRAFANA_DASHBOARDS_DIR=./grafana/dashboards
# GRAFANA_DASHBOARDS_CFG=./grafana/dashboards.yml

# ─── Límites de recursos (opcional) ────────────────────────
# Descomentar para restringir CPU/RAM por servicio
# LIMIT_CPU_APP=0.5
# LIMIT_MEM_APP=256M
# LIMIT_CPU_POSTGRES=0.5
# LIMIT_MEM_POSTGRES=256M
# LIMIT_CPU_GRAFANA=0.3
# LIMIT_MEM_GRAFANA=256M
# LIMIT_CPU_MIMIR=0.5
# LIMIT_MEM_MIMIR=512M
# LIMIT_CPU_LOKI=0.3
# LIMIT_MEM_LOKI=256M
# LIMIT_CPU_TEMPO=0.3
# LIMIT_MEM_TEMPO=256M
# LIMIT_CPU_OTEL=0.3
# LIMIT_MEM_OTEL=256M
# LIMIT_CPU_CADVISOR=0.2
# LIMIT_MEM_CADVISOR=128M
# LIMIT_CPU_NODE_EXPORTER=0.1
# LIMIT_MEM_NODE_EXPORTER=64M
# LIMIT_CPU_PG_EXPORTER=0.1
# LIMIT_MEM_PG_EXPORTER=64M

# ─── Logging (Docker) ─────────────────────────────────────
# LOG_MAX_SIZE=10m
# LOG_MAX_FILE=3

# ─── Puerto del host (para evitar conflictos) ──────────────
# HOST_PORT_APP=3001
# HOST_PORT_GRAFANA=3000
# HOST_PORT_POSTGRES=5432
# HOST_PORT_MIMIR=9009
# HOST_PORT_LOKI=3100
# HOST_PORT_TEMPO=3200
# HOST_PORT_CADVISOR=8080
# HOST_PORT_NODE_EXPORTER=9100
# HOST_PORT_PG_EXPORTER=9187
