{
  "__inputs": [],
  "__requires": [],
  "title": "Base de Datos - PostgreSQL",
  "uid": "postgres-db",
  "version": 2,
  "schemaVersion": 40,
  "editable": true,
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "tags": ["taller", "postgres", "database"],
  "panels": [
    {
      "title": "Tamaño de la Base de Datos",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000000 },
              { "color": "red", "value": 50000000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"taller\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Backends Conectados",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"taller\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Límite de Conexiones",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_database_connection_limit{datname=\"taller\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Conexiones Activas por Estado",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "avg(pg_stat_activity_count{datname=~\"taller|postgres\"}) by (datname, state)",
          "legendFormat": "{{datname}} - {{state}}"
        }
      ]
    },
    {
      "title": "Transacciones por segundo",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "cps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit_total{datname=~\"taller|postgres\"}[$__rate_interval])",
          "legendFormat": "commit - {{datname}}"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback_total{datname=~\"taller|postgres\"}[$__rate_interval])",
          "legendFormat": "rollback - {{datname}}"
        }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit_total{datname=~\"taller|postgres\"}[$__rate_interval])) by (datname) / (sum(rate(pg_stat_database_blks_hit_total{datname=~\"taller|postgres\"}[$__rate_interval])) by (datname) + sum(rate(pg_stat_database_blks_read_total{datname=~\"taller|postgres\"}[$__rate_interval])) by (datname))",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Operaciones de Lectura/Escritura",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "rows/s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched_total{datname=~\"taller|postgres\"}[$__rate_interval])",
          "legendFormat": "lecturas - {{datname}}"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted_total{datname=~\"taller|postgres\"}[$__rate_interval])",
          "legendFormat": "inserciones - {{datname}}"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated_total{datname=~\"taller|postgres\"}[$__rate_interval])",
          "legendFormat": "actualizaciones - {{datname}}"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted_total{datname=~\"taller|postgres\"}[$__rate_interval])",
          "legendFormat": "borrados - {{datname}}"
        }
      ]
    },
    {
      "title": "Deadlocks y Conflictos",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "cps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks_total{datname=~\"taller|postgres\"}[$__rate_interval])",
          "legendFormat": "deadlocks - {{datname}}"
        },
        {
          "expr": "rate(pg_stat_database_conflicts_total{datname=~\"taller|postgres\"}[$__rate_interval])",
          "legendFormat": "conflictos - {{datname}}"
        }
      ]
    }
  ]
}
