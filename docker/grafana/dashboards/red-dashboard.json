{
  "__inputs": [],
  "__requires": [],
  "title": "RED - Backend",
  "uid": "red-backend",
  "version": 2,
  "schemaVersion": 40,
  "editable": true,
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "tags": ["taller", "red", "metrics"],
  "panels": [
    {
      "title": "Rate de Requests",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "req/s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_server_duration_milliseconds_count[$__rate_interval])",
          "legendFormat": "{{http_method}} {{http_status_code}}"
        }
      ]
    },
    {
      "title": "Tasa de Errores (4xx)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "req/s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_server_duration_milliseconds_count{http_status_code=~\"4..\"}[$__rate_interval])",
          "legendFormat": "{{http_method}} {{http_status_code}}"
        }
      ]
    },
    {
      "title": "Latencia (p95)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_duration_milliseconds_bucket[$__rate_interval]))",
          "legendFormat": "{{http_method}}"
        }
      ]
    }
  ]
}
